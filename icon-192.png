// Browser ZIP export is implemented in standalone.js for file:// support.
// This placeholder documents the intended boundary for a React/Node version:
// collect Blob entries, add original/metadata, and stream a ZIP download.
export interface ZipEntry {
  path: string;
  blob: Blob;
}

export async function createZipEntries(entries: ZipEntry[]): Promise<ZipEntry[]> {
  return entries;
}
