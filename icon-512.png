const ACCEPTED_TYPES = ["image/jpeg", "image/png", "image/webp"];
const EXPORT_SIZES = {
  original: { label: "원본", folder: "cuts_original", suffix: "", width: null, height: null },
  "1920x1080": { label: "1920x1080", folder: "cuts_1920x1080", suffix: "_1920x1080", width: 1920, height: 1080 },
  "3840x2160": { label: "3840x2160", folder: "cuts_3840x2160", suffix: "_3840x2160", width: 3840, height: 2160 },
  "1080x1920": { label: "1080x1920", folder: "cuts_1080x1920", suffix: "_1080x1920", width: 1080, height: 1920 },
  "1080x1080": { label: "1080x1080", folder: "cuts_1080x1080", suffix: "_1080x1080", width: 1080, height: 1080 },
  "1080x1350": { label: "1080x1350", folder: "cuts_1080x1350", suffix: "_1080x1350", width: 1080, height: 1350 }
};

const state = {
  sourceFile: null,
  image: null,
  imageUrl: "",
  sourceCanvas: null,
  cuts: [],
  draft: null,
  manualMode: false,
  busy: false,
  exportFormat: "png",
  exportSizes: ["original", "1920x1080"],
  projectName: "storyboard-project",
  quality: 95,
  upscale: "none",
  upscaleAfterSave: false,
  includeMetadata: true
};

const els = {
  topFileInput: document.querySelector("#topFileInput"),
  dropFileInput: document.querySelector("#dropFileInput"),
  pickButton: document.querySelector("#pickButton"),
  manualButton: document.querySelector("#manualButton"),
  cancelButton: document.querySelector("#cancelButton"),
  resetButton: document.querySelector("#resetButton"),
  zipButton: document.querySelector("#zipButton"),
  projectNameInput: document.querySelector("#projectNameInput"),
  formatSelect: document.querySelector("#formatSelect"),
  upscaleSelect: document.querySelector("#upscaleSelect"),
  upscaleAfterSaveInput: document.querySelector("#upscaleAfterSaveInput"),
  qualityInput: document.querySelector("#qualityInput"),
  metadataVisibleInput: document.querySelector("#metadataVisibleInput"),
  previewExportsButton: document.querySelector("#previewExportsButton"),
  downloadZipButton: document.querySelector("#downloadZipButton"),
  exportPreviewPanel: document.querySelector("#exportPreviewPanel"),
  exportPreviewGrid: document.querySelector("#exportPreviewGrid"),
  previewStage: document.querySelector("#previewStage"),
  cutsGrid: document.querySelector("#cutsGrid"),
  cutCount: document.querySelector("#cutCount"),
  statusText: document.querySelector("#statusText")
};

let dragStart = null;
const cutPreviewUrls = [];
const exportPreviewUrls = [];

function makeId() {
  return crypto.randomUUID ? crypto.randomUUID() : `cut-${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function defaultCutName(index) {
  return `cut_${String(index + 1).padStart(2, "0")}`;
}

function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

function setStatus(message, busy = state.busy) {
  state.busy = busy;
  els.statusText.textContent = busy ? "작업 중..." : message;
  els.manualButton.disabled = !state.image || busy;
  els.cancelButton.disabled = !state.image || busy || (!state.manualMode && !state.draft);
  els.resetButton.disabled = !state.image || busy;
  els.zipButton.disabled = !state.cuts.length || busy;
  els.downloadZipButton.disabled = !state.cuts.length || busy;
  els.previewExportsButton.disabled = !state.cuts.length || busy;
}

function clearObjectUrls(urls) {
  while (urls.length) URL.revokeObjectURL(urls.pop());
}

function safeName(value, fallback = "storyboard-project") {
  const cleaned = String(value || "")
    .trim()
    .replace(/[\\/:*?"<>|]+/g, "_")
    .replace(/\s+/g, "_")
    .replace(/_+/g, "_")
    .replace(/^_|_$/g, "");
  return cleaned || fallback;
}

function exportExtension() {
  if (state.exportFormat === "jpeg") return "jpg";
  if (state.exportFormat === "webp") return "webp";
  return "png";
}

function exportMimeType() {
  if (state.exportFormat === "jpeg") return "image/jpeg";
  if (state.exportFormat === "webp") return "image/webp";
  return "image/png";
}

function exportButtonLabel() {
  if (state.exportFormat === "jpeg") return "JPG";
  if (state.exportFormat === "webp") return "WEBP";
  return "PNG";
}

function selectedExportSizes() {
  const checked = [...document.querySelectorAll('input[name="exportSize"]:checked')].map((input) => input.value);
  state.exportSizes = checked.length ? checked : ["original"];
  return state.exportSizes;
}

function buildExportFileName(cut, index, sizeKey) {
  const base = safeName(cut.name, defaultCutName(index));
  const ext = exportExtension();
  if (sizeKey === "original") return `${base}_original.${ext}`;
  const config = EXPORT_SIZES[sizeKey];
  return `${base}${config.suffix}_cover.${ext}`;
}

function getCanvasBlob(canvas, mimeType = "image/png", quality = 0.95) {
  return new Promise((resolve, reject) => {
    canvas.toBlob(
      (blob) => {
        if (blob) resolve(blob);
        else reject(new Error("이미지 파일을 만들 수 없습니다."));
      },
      mimeType,
      quality
    );
  });
}

function downloadBlob(blob, fileName) {
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.href = url;
  link.download = fileName;
  document.body.appendChild(link);
  link.click();
  link.remove();
  setTimeout(() => URL.revokeObjectURL(url), 3000);
}

async function handleFile(file) {
  if (!file) return;
  if (!ACCEPTED_TYPES.includes(file.type)) {
    setStatus("JPG, PNG, WEBP 파일만 업로드할 수 있습니다.", false);
    return;
  }

  setStatus("이미지를 불러오는 중입니다.", true);
  if (state.imageUrl) URL.revokeObjectURL(state.imageUrl);

  const url = URL.createObjectURL(file);
  const image = new Image();
  image.decoding = "async";
  image.src = url;

  try {
    await image.decode();
    const canvas = document.createElement("canvas");
    canvas.width = image.naturalWidth;
    canvas.height = image.naturalHeight;
    const ctx = canvas.getContext("2d");
    ctx.drawImage(image, 0, 0);

    clearObjectUrls(cutPreviewUrls);
    clearObjectUrls(exportPreviewUrls);
    state.sourceFile = file;
    state.image = image;
    state.imageUrl = url;
    state.sourceCanvas = canvas;
    state.cuts = [];
    state.draft = null;
    state.manualMode = true;
    els.exportPreviewPanel.hidden = true;
    els.exportPreviewGrid.innerHTML = "";
    render();
    setStatus("이미지를 불러왔습니다. 드래그해서 컷 영역을 선택하세요.", false);
  } catch (error) {
    URL.revokeObjectURL(url);
    setStatus("이미지를 불러오지 못했습니다.", false);
  }
}

function drawPreview() {
  els.previewStage.innerHTML = "";

  if (!state.image) {
    const label = document.createElement("label");
    label.className = "dropTarget";
    label.innerHTML = `
      <input id="dropFileInput" type="file" accept="image/jpeg,image/png,image/webp" />
      <strong>스토리보드 이미지 업로드</strong>
      <span>JPG, PNG, WEBP</span>
    `;
    const input = label.querySelector("#dropFileInput");
    input.addEventListener("change", (event) => {
      handleFile(event.target.files?.[0]);
    });
    els.previewStage.append(label);
    els.dropFileInput = input;
    return;
  }

  const shell = document.createElement("div");
  shell.className = "canvasShell";

  const canvas = document.createElement("canvas");
  canvas.width = state.image.width;
  canvas.height = state.image.height;
  const ctx = canvas.getContext("2d");
  ctx.drawImage(state.image, 0, 0);
  shell.append(canvas);

  state.cuts.forEach((cut, index) => {
    const box = document.createElement("div");
    box.className = "cutBox";
    box.style.left = `${(cut.x / state.image.width) * 100}%`;
    box.style.top = `${(cut.y / state.image.height) * 100}%`;
    box.style.width = `${(cut.width / state.image.width) * 100}%`;
    box.style.height = `${(cut.height / state.image.height) * 100}%`;
    box.dataset.label = String(index + 1).padStart(2, "0");
    shell.append(box);
  });

  if (state.draft) {
    const draft = document.createElement("div");
    draft.className = "cutBox draft";
    draft.style.left = `${(state.draft.x / state.image.width) * 100}%`;
    draft.style.top = `${(state.draft.y / state.image.height) * 100}%`;
    draft.style.width = `${(state.draft.width / state.image.width) * 100}%`;
    draft.style.height = `${(state.draft.height / state.image.height) * 100}%`;
    draft.dataset.label = "선택";
    shell.append(draft);
  }

  els.previewStage.append(shell);
}

function pointerToImagePoint(event) {
  const canvas = els.previewStage.querySelector("canvas");
  const rect = canvas.getBoundingClientRect();
  return {
    x: clamp(((event.clientX - rect.left) / rect.width) * state.image.width, 0, state.image.width),
    y: clamp(((event.clientY - rect.top) / rect.height) * state.image.height, 0, state.image.height)
  };
}

function normalizeDraft(start, end) {
  const x = Math.min(start.x, end.x);
  const y = Math.min(start.y, end.y);
  const width = Math.abs(end.x - start.x);
  const height = Math.abs(end.y - start.y);
  return { x, y, width, height };
}

function addDraftAsCut() {
  if (!state.draft || state.draft.width < 8 || state.draft.height < 8) {
    state.draft = null;
    render();
    return;
  }

  const index = state.cuts.length;
  state.cuts.push({
    id: makeId(),
    name: defaultCutName(index),
    x: state.draft.x,
    y: state.draft.y,
    width: state.draft.width,
    height: state.draft.height
  });
  state.draft = null;
  render();
  setStatus("컷을 추가했습니다.", false);
}

function selectedBox(cut) {
  return {
    x: clamp(cut.x, 0, state.sourceCanvas.width - 1),
    y: clamp(cut.y, 0, state.sourceCanvas.height - 1),
    width: Math.max(1, Math.min(cut.width, state.sourceCanvas.width - cut.x)),
    height: Math.max(1, Math.min(cut.height, state.sourceCanvas.height - cut.y))
  };
}

function selectedCanvas(cut) {
  const box = selectedBox(cut);
  const canvas = document.createElement("canvas");
  canvas.width = Math.max(1, Math.round(box.width));
  canvas.height = Math.max(1, Math.round(box.height));
  const ctx = canvas.getContext("2d");
  ctx.drawImage(state.sourceCanvas, box.x, box.y, box.width, box.height, 0, 0, canvas.width, canvas.height);
  return canvas;
}

function upscaleFactor() {
  if (!state.upscaleAfterSave) return 1;
  if (state.upscale === "2x") return 2;
  if (state.upscale === "4x") return 4;
  return 1;
}

function exportCanvasSize(cut, sizeKey) {
  const box = selectedBox(cut);
  const config = EXPORT_SIZES[sizeKey] || EXPORT_SIZES.original;
  const factor = sizeKey === "original" ? upscaleFactor() : 1;
  return {
    width: Math.max(1, Math.round((config.width || box.width) * factor)),
    height: Math.max(1, Math.round((config.height || box.height) * factor))
  };
}

function applySharpen(ctx, width, height) {
  if (width * height > 12000000) return;
  const imageData = ctx.getImageData(0, 0, width, height);
  const src = imageData.data;
  const out = new Uint8ClampedArray(src);
  const amount = 0.35;

  for (let y = 1; y < height - 1; y += 1) {
    for (let x = 1; x < width - 1; x += 1) {
      const i = (y * width + x) * 4;
      for (let c = 0; c < 3; c += 1) {
        const center = src[i + c] * (1 + 4 * amount);
        const neighbors = src[i - 4 + c] + src[i + 4 + c] + src[i - width * 4 + c] + src[i + width * 4 + c];
        out[i + c] = clamp(center - neighbors * amount, 0, 255);
      }
    }
  }

  imageData.data.set(out);
  ctx.putImageData(imageData, 0, 0);
}

async function exportCutBlob(cut, sizeKey) {
  const source = selectedCanvas(cut);
  const size = exportCanvasSize(cut, sizeKey);
  const canvas = document.createElement("canvas");
  canvas.width = size.width;
  canvas.height = size.height;
  const ctx = canvas.getContext("2d");
  ctx.imageSmoothingEnabled = true;
  ctx.imageSmoothingQuality = "high";

  const scale = Math.max(size.width / source.width, size.height / source.height);
  const drawWidth = source.width * scale;
  const drawHeight = source.height * scale;
  const offsetX = (size.width - drawWidth) / 2;
  const offsetY = (size.height - drawHeight) / 2;

  ctx.drawImage(source, offsetX, offsetY, drawWidth, drawHeight);
  if (state.upscaleAfterSave && state.upscale !== "none") applySharpen(ctx, size.width, size.height);
  return getCanvasBlob(canvas, exportMimeType(), clamp(Number(state.quality) || 95, 80, 100) / 100);
}

function renderCuts() {
  clearObjectUrls(cutPreviewUrls);
  els.cutsGrid.innerHTML = "";
  els.cutCount.textContent = `${state.cuts.length} 컷`;

  if (!state.cuts.length) {
    els.cutsGrid.innerHTML = `<div class="emptyState">선택한 컷이 여기에 표시됩니다.</div>`;
    return;
  }

  state.cuts.forEach((cut, index) => {
    const card = document.createElement("article");
    card.className = "cutCard";

    const previewCanvas = selectedCanvas(cut);
    const previewUrl = previewCanvas.toDataURL("image/png");
    const sizeLabel = exportCanvasSize(cut, selectedExportSizes()[0]);
    const extra = state.exportSizes.length > 1 ? ` 외 ${state.exportSizes.length - 1}개` : "";

    card.innerHTML = `
      <div class="cutPreview">
        <img src="${previewUrl}" alt="${cut.name} 미리보기" />
        <span>${String(index + 1).padStart(2, "0")}</span>
      </div>
      <div class="cutInfo">
        <input type="text" value="${cut.name}" aria-label="컷 이름" />
        <small>${sizeLabel.width} x ${sizeLabel.height}${extra}, ${exportButtonLabel()}, 꽉 차게</small>
        <div class="cutActions">
          <button type="button" title="앞으로">↑</button>
          <button type="button" title="뒤로">↓</button>
          <button type="button" title="선택 사이즈 다운로드">선택 다운로드</button>
          <button type="button" class="danger" title="삭제">삭제</button>
        </div>
      </div>
    `;

    const input = card.querySelector("input");
    const buttons = card.querySelectorAll("button");
    input.addEventListener("input", () => {
      cut.name = input.value;
    });
    buttons[0].addEventListener("click", () => moveCut(index, -1));
    buttons[1].addEventListener("click", () => moveCut(index, 1));
    buttons[2].addEventListener("click", () => downloadCut(cut, index));
    buttons[3].addEventListener("click", () => deleteCut(cut.id));

    els.cutsGrid.append(card);
  });
}

function moveCut(index, direction) {
  const nextIndex = index + direction;
  if (nextIndex < 0 || nextIndex >= state.cuts.length) return;
  const [cut] = state.cuts.splice(index, 1);
  state.cuts.splice(nextIndex, 0, cut);
  render();
}

function deleteCut(id) {
  state.cuts = state.cuts.filter((cut) => cut.id !== id);
  render();
  setStatus("컷을 삭제했습니다.", false);
}

async function downloadCut(cut, index) {
  selectedExportSizes();
  const files = [];
  for (const sizeKey of state.exportSizes) {
    const blob = await exportCutBlob(cut, sizeKey);
    files.push({ path: `${cut.name}/${sizeKey}/${buildExportFileName(cut, index, sizeKey)}`, blob });
  }
  if (files.length === 1) {
    downloadBlob(files[0].blob, buildExportFileName(cut, index, state.exportSizes[0]));
    return;
  }
  const zip = await createZip(files);
  downloadBlob(zip, `${safeName(cut.name, defaultCutName(index))}.zip`);
}

async function generateExportPreview() {
  if (!state.cuts.length) {
    setStatus("미리보기할 컷이 없습니다.", false);
    return;
  }

  selectedExportSizes();
  clearObjectUrls(exportPreviewUrls);
  els.exportPreviewGrid.innerHTML = "";
  els.exportPreviewPanel.hidden = false;

  for (const [cutIndex, cut] of state.cuts.entries()) {
    const group = document.createElement("details");
    group.className = "exportPreviewGroup";
    group.open = cutIndex === 0;
    group.innerHTML = `<summary>${safeName(cut.name, defaultCutName(cutIndex))} 미리보기</summary><div class="exportPreviewItems"></div>`;
    const items = group.querySelector(".exportPreviewItems");

    for (const sizeKey of state.exportSizes) {
      const blob = await exportCutBlob(cut, sizeKey);
      const url = URL.createObjectURL(blob);
      exportPreviewUrls.push(url);
      const size = exportCanvasSize(cut, sizeKey);
      const item = document.createElement("figure");
      item.className = "exportPreviewItem";
      item.innerHTML = `
        <img src="${url}" alt="${EXPORT_SIZES[sizeKey].label} 저장 미리보기" />
        <figcaption>${EXPORT_SIZES[sizeKey].label} · ${size.width} x ${size.height}</figcaption>
      `;
      items.append(item);
    }

    els.exportPreviewGrid.append(group);
  }

  drawPreview();
  setStatus("선택 사이즈 미리보기를 생성했습니다.", false);
}

function createMetadata(projectName, sizes, exportsByCut) {
  return {
    projectName,
    createdAt: new Date().toISOString(),
    originalFileName: state.sourceFile?.name || "",
    totalCuts: state.cuts.length,
    exportOptions: {
      sizes,
      resizeMode: "cover",
      fitMode: false,
      containMode: false,
      fillCanvas: true,
      allowCrop: true,
      letterbox: false,
      useBlurBackground: false,
      format: state.exportFormat,
      quality: state.quality,
      upscale: state.upscaleAfterSave ? state.upscale : "none"
    },
    cuts: state.cuts.map((cut, index) => ({
      id: index + 1,
      name: safeName(cut.name, defaultCutName(index)),
      x: Math.round(cut.x),
      y: Math.round(cut.y),
      width: Math.round(cut.width),
      height: Math.round(cut.height),
      exports: exportsByCut[index] || []
    }))
  };
}

async function downloadZip() {
  if (!state.cuts.length || !state.sourceCanvas) {
    setStatus("다운로드할 컷이 없습니다.", false);
    return;
  }

  selectedExportSizes();
  const projectName = safeName(state.projectName || els.projectNameInput.value, "storyboard-project");
  setStatus("ZIP 파일을 만드는 중입니다.", true);
  await generateExportPreview();

  const files = [];
  const exportsByCut = [];
  const originalBlob = await getCanvasBlob(state.sourceCanvas, "image/png");
  files.push({ path: `${projectName}/original/storyboard_original.png`, blob: originalBlob });

  for (const [cutIndex, cut] of state.cuts.entries()) {
    const exportNames = [];
    for (const sizeKey of state.exportSizes) {
      const blob = await exportCutBlob(cut, sizeKey);
      const fileName = buildExportFileName(cut, cutIndex, sizeKey);
      exportNames.push(fileName);
      files.push({
        path: `${projectName}/${EXPORT_SIZES[sizeKey].folder}/${fileName}`,
        blob
      });
    }
    exportsByCut[cutIndex] = exportNames;
  }

  if (state.includeMetadata) {
    const metadata = createMetadata(projectName, state.exportSizes, exportsByCut);
    files.push({
      path: `${projectName}/metadata.json`,
      blob: new Blob([JSON.stringify(metadata, null, 2)], { type: "application/json" })
    });
  }

  const zip = await createZip(files);
  downloadBlob(zip, `${projectName}.zip`);
  setStatus("ZIP 파일이 준비되었습니다.", false);
}

function render() {
  drawPreview();
  renderCuts();
  setStatus(state.image ? "드래그해서 컷 영역을 선택하세요." : "이미지를 업로드하면 컷 선택을 시작할 수 있습니다.", false);
}

function cancelSelection() {
  state.draft = null;
  state.manualMode = false;
  render();
  setStatus("선택을 취소했습니다.", false);
}

function resetAll() {
  clearObjectUrls(cutPreviewUrls);
  clearObjectUrls(exportPreviewUrls);
  if (state.imageUrl) URL.revokeObjectURL(state.imageUrl);
  state.sourceFile = null;
  state.image = null;
  state.imageUrl = "";
  state.sourceCanvas = null;
  state.cuts = [];
  state.draft = null;
  state.manualMode = false;
  dragStart = null;
  els.exportPreviewPanel.hidden = true;
  els.exportPreviewGrid.innerHTML = "";
  if (els.topFileInput) els.topFileInput.value = "";
  render();
}

function bindEvents() {
  els.pickButton.addEventListener("click", () => els.topFileInput.click());
  els.topFileInput.addEventListener("change", (event) => handleFile(event.target.files?.[0]));
  if (els.dropFileInput) {
    els.dropFileInput.addEventListener("change", (event) => handleFile(event.target.files?.[0]));
  }

  els.manualButton.addEventListener("click", () => {
    state.manualMode = !state.manualMode;
    setStatus(state.manualMode ? "원본 이미지 위에서 드래그해 컷을 추가하세요." : "수동 선택을 종료했습니다.", false);
  });
  els.cancelButton.addEventListener("click", cancelSelection);
  els.resetButton.addEventListener("click", resetAll);
  els.zipButton.addEventListener("click", downloadZip);
  els.downloadZipButton.addEventListener("click", downloadZip);
  els.previewExportsButton.addEventListener("click", generateExportPreview);

  els.projectNameInput.addEventListener("input", () => {
    state.projectName = els.projectNameInput.value;
  });
  els.formatSelect.addEventListener("change", () => {
    state.exportFormat = els.formatSelect.value;
    renderCuts();
    setStatus(`${exportButtonLabel()}로 저장하도록 설정했습니다.`, false);
  });
  els.upscaleSelect.addEventListener("change", () => {
    state.upscale = els.upscaleSelect.value;
    renderCuts();
  });
  els.upscaleAfterSaveInput.addEventListener("change", () => {
    state.upscaleAfterSave = els.upscaleAfterSaveInput.checked;
    renderCuts();
  });
  els.qualityInput.addEventListener("input", () => {
    state.quality = clamp(Number(els.qualityInput.value) || 95, 80, 100);
  });
  els.metadataVisibleInput.addEventListener("change", () => {
    state.includeMetadata = els.metadataVisibleInput.checked;
  });
  document.querySelectorAll('input[name="exportSize"]').forEach((input) => {
    input.addEventListener("change", () => {
      selectedExportSizes();
      renderCuts();
      setStatus(`선택한 출력 사이즈 ${state.exportSizes.length}개를 저장합니다.`, false);
    });
  });

  els.previewStage.addEventListener("dragover", (event) => event.preventDefault());
  els.previewStage.addEventListener("drop", (event) => {
    event.preventDefault();
    handleFile(event.dataTransfer.files?.[0]);
  });
  els.previewStage.addEventListener("pointerdown", (event) => {
    if (!state.image || !state.manualMode || !event.target.closest(".canvasShell")) return;
    dragStart = pointerToImagePoint(event);
    state.draft = { x: dragStart.x, y: dragStart.y, width: 0, height: 0 };
    drawPreview();
  });
  els.previewStage.addEventListener("pointermove", (event) => {
    if (!dragStart || !state.image) return;
    const current = pointerToImagePoint(event);
    state.draft = normalizeDraft(dragStart, current);
    drawPreview();
  });
  els.previewStage.addEventListener("pointerup", () => {
    if (!dragStart) return;
    dragStart = null;
    addDraftAsCut();
  });
}

const zipEncoder = new TextEncoder();
const crcTable = createCrcTable();

function createCrcTable() {
  const table = new Uint32Array(256);
  for (let i = 0; i < 256; i += 1) {
    let value = i;
    for (let bit = 0; bit < 8; bit += 1) {
      value = value & 1 ? 0xedb88320 ^ (value >>> 1) : value >>> 1;
    }
    table[i] = value >>> 0;
  }
  return table;
}

function crc32(bytes) {
  let crc = 0xffffffff;
  for (const byte of bytes) {
    crc = crcTable[(crc ^ byte) & 0xff] ^ (crc >>> 8);
  }
  return (crc ^ 0xffffffff) >>> 0;
}

function localFileHeader(nameBytes, crc, size) {
  const buffer = new Uint8Array(30 + nameBytes.length);
  const view = new DataView(buffer.buffer);
  view.setUint32(0, 0x04034b50, true);
  view.setUint16(4, 20, true);
  view.setUint16(6, 0, true);
  view.setUint16(8, 0, true);
  view.setUint16(10, 0, true);
  view.setUint16(12, 0, true);
  view.setUint32(14, crc, true);
  view.setUint32(18, size, true);
  view.setUint32(22, size, true);
  view.setUint16(26, nameBytes.length, true);
  view.setUint16(28, 0, true);
  buffer.set(nameBytes, 30);
  return buffer;
}

function centralDirectoryHeader(nameBytes, crc, size, offset) {
  const buffer = new Uint8Array(46 + nameBytes.length);
  const view = new DataView(buffer.buffer);
  view.setUint32(0, 0x02014b50, true);
  view.setUint16(4, 20, true);
  view.setUint16(6, 20, true);
  view.setUint16(8, 0, true);
  view.setUint16(10, 0, true);
  view.setUint16(12, 0, true);
  view.setUint16(14, 0, true);
  view.setUint32(16, crc, true);
  view.setUint32(20, size, true);
  view.setUint32(24, size, true);
  view.setUint16(28, nameBytes.length, true);
  view.setUint16(30, 0, true);
  view.setUint16(32, 0, true);
  view.setUint16(34, 0, true);
  view.setUint16(36, 0, true);
  view.setUint32(38, 0, true);
  view.setUint32(42, offset, true);
  buffer.set(nameBytes, 46);
  return buffer;
}

function endOfCentralDirectory(fileCount, centralSize, centralOffset) {
  const buffer = new Uint8Array(22);
  const view = new DataView(buffer.buffer);
  view.setUint32(0, 0x06054b50, true);
  view.setUint16(4, 0, true);
  view.setUint16(6, 0, true);
  view.setUint16(8, fileCount, true);
  view.setUint16(10, fileCount, true);
  view.setUint32(12, centralSize, true);
  view.setUint32(16, centralOffset, true);
  view.setUint16(20, 0, true);
  return buffer;
}

async function createZip(files) {
  const localParts = [];
  const centralParts = [];
  let offset = 0;

  for (const file of files) {
    const bytes = new Uint8Array(await file.blob.arrayBuffer());
    const nameBytes = zipEncoder.encode(file.path.replaceAll("\\", "/"));
    const crc = crc32(bytes);
    const localHeader = localFileHeader(nameBytes, crc, bytes.length);
    const centralHeader = centralDirectoryHeader(nameBytes, crc, bytes.length, offset);
    localParts.push(localHeader, bytes);
    centralParts.push(centralHeader);
    offset += localHeader.length + bytes.length;
  }

  const centralSize = centralParts.reduce((sum, part) => sum + part.length, 0);
  const end = endOfCentralDirectory(files.length, centralSize, offset);
  return new Blob([...localParts, ...centralParts, end], { type: "application/zip" });
}

bindEvents();
render();
